# --- GitHub OAuth App (Settings -> Developer settings -> OAuth Apps) --------
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Target repository ------------------------------------------------------
# Repo-agnostic mode: leave OWNER/REPO empty and keep ALLOW_REPO_OVERRIDE=true
# to let one deployment launch a Codespace for ANY repo the user's token can
# open (owner/repo passed per request as ?owner=…&repo=…). The target repo
# needs no artifacts — Variant A attaches over the gh SSH tunnel.
# Or pin a single default repo by setting OWNER/REPO below.
GITHUB_OWNER=
GITHUB_REPO=
ALLOW_REPO_OVERRIDE=true
GITHUB_REF=main
# Optional machine type, e.g. basicLinux32gb (empty = GitHub default)
CODESPACE_MACHINE=

# --- Server ------------------------------------------------------------------
PORT=3000
# Must match the OAuth App callback host exactly
BASE_URL=http://localhost:3000
# Long random string, e.g. `openssl rand -base64 48`
SESSION_SECRET=change-me

# --- Lifecycle ----------------------------------------------------------------
# Bridge-level idle timeout (no bytes in either direction) in milliseconds
IDLE_TIMEOUT_MS=600000
# GitHub-side idle timeout for the Codespace itself, in minutes (safety net)
CODESPACE_IDLE_TIMEOUT_MINUTES=30
# Session lifetime in milliseconds (default 8h)
SESSION_TTL_MS=28800000
