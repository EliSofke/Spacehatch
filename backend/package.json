{
  "name": "spacehatch-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Spacehatch: one-click cloud terminal that launches a GitHub Codespace and bridges its shell to the browser via SSH + WebSocket.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsc -p tsconfig.json --watch & node --watch dist/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "ssh2": "^1.16.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.1",
    "@types/ws": "^8.5.12",
    "typescript": "^5.5.4"
  }
}
